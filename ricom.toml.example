# ricom configuration (TOML). Copy to ~/.config/ricom/ricom.toml and edit.
# Every key is optional — omitted keys fall back to these built-in defaults.
# Reload a running ricom live with:  kill -HUP $(pidof ricom)

# unredir-if-possible: let a lone fullscreen window bypass the compositor and
# page-flip straight to the display (compositor cost ~0). Set to false to always
# composite — even when a single fullscreen window is the only thing on screen.
unredir = true

# Composite background colour (RGB, 0.0-1.0), seen where no window covers.
background = [0.05, 0.05, 0.07]

# Window corner radius in px (0 = square corners).
corner_radius = 0.0

# Default opacity for windows that set no _NET_WM_WINDOW_OPACITY and match no rule
# (0.0-1.0; 1.0 = opaque). The bottom layer of the opacity stack (see [[rule]]).
default_opacity = 1.0

[fade]
enabled = true
duration = 0.2      # seconds (fade in on map, out on unmap/destroy)

[shadow]
enabled = true
radius = 12.0       # left/bottom falloff distance (px)
strength = 0.45     # peak shadow alpha (0.0-1.0)
min_size = 24       # skip shadows for windows smaller than this (px)

[blur]
enabled = false     # frost the backdrop behind translucent windows (extra GPU cost)
passes = 3          # dual-Kawase iterations (more = wider/softer)
radius = 4.0        # sample offset per pass (px)

[animation]
enabled = true          # scale-about-centre "pop" on open/close (pop speed follows [fade] duration;
                        # the [fade] opacity fade still applies when this is false)
open_scale = 0.85       # start scale on open / end scale on close (1.0 = no pop)
wobble = true           # wobbly-windows: a spring-mesh jelly that lags/jiggles on move/resize
wobble_spring = 350.0   # spring stiffness k (higher = snappier, faster settle)
wobble_friction = 14.0  # velocity damping (higher = less jiggle, settles sooner)

[burn]
# Burn/dissolve close effect. These two size knobs are live-tunable: edit and
# reload with  kill -HUP $(pidof ricom)  then close a window to see the change.
seg_scale = 36.0        # segment/hole granularity (higher = finer, smaller patches)
ember_width = 0.07      # ember hot-band half-width (smaller = thinner, tighter glow)
ember_cool = [0.28, 0.02, 0.0]  # cooler trailing ember colour (edge of the glow)
ember_hot  = [0.75, 0.22, 0.04] # hottest leading-edge colour; raise both for a brighter fire

[fps]
enabled = false          # start with the on-demand FPS HUD visible (also toggles live via the hotkey)
hotkey = "Super+Shift+F" # toggle the HUD (XGrabKey); the hotkey's modifiers + arrow keys move it
                         # between corners live (e.g. Super+Shift+Left)
corner = "top-right"     # initial corner: top-left | top-right | bottom-left | bottom-right
graph = true             # draw the rolling frame-time graph under the numbers
scale = 1.0              # size multiplier on top of automatic screen-height scaling (4K = 2x)
# The HUD also shows a 1m/5m/15m load block (fps + GPU render ms); the same
# figures are logged on demand via  kill -USR1 $(pidof ricom)

# Per-window rules. Each [[rule]] has a `match` (all listed conditions must hold —
# class/instance/window_type match exactly, title matches as a substring,
# fullscreen matches state) plus the settings it overrides. Rules apply in order,
# last match wins per field. A built-in rule already keeps fullscreen windows
# opaque + unblurred; add your own to override. Examples (uncomment to use):

# [[rule]]
# match = { class = "mpv" }         # video: never dim or blur, keep it crisp
# opacity = 1.0
# blur = false
# shadow = false

# [[rule]]
# match = { class = "com.mitchellh.ghostty" }  # frosted terminals (Ghostty's default
# opacity = 0.85                                # X11 class; confirm with `xprop WM_CLASS`,
# blur = true                                   # or set it via Ghostty's own `class` option)

# [[rule]]
# match = { window_type = "dock" }  # no shadow on panels/bars
# shadow = false

# [[rule]]
# match = { title = "Picture-in-Picture" }
# corner_radius = 12.0
