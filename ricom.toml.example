# ricom configuration (TOML). Copy to ~/.config/ricom/ricom.toml and edit.
# Every key is optional — omitted keys fall back to these built-in defaults.
# Reload a running ricom live with:  kill -HUP $(pidof ricom)
# Dump the effective config with:    ricom --print-config

# unredir-if-possible: let a lone fullscreen window bypass the compositor and
# page-flip straight to the display (compositor cost ~0). Set to false to always
# composite — even when a single fullscreen window is the only thing on screen.
unredir = true

# Composite background colour (RGB, 0.0-1.0), seen where no window covers.
background = [0.05, 0.05, 0.07]

# Window corner radius in px (0 = square corners).
corner_radius = 0.0

# Default opacity for windows that set no _NET_WM_WINDOW_OPACITY and match no rule
# (0.0-1.0; 1.0 = opaque). The bottom layer of the opacity stack (see [[rule]]).
default_opacity = 1.0

# ── Animations ───────────────────────────────────────────────────────────────
# Each lifecycle transition — open (map), close (unmap/destroy), move (resize) —
# plays a set of composable "blocks" (primitives) that layer together. Pick a
# named PRESET, or compose blocks explicitly (see below). Per-window overrides go
# on a [[rule]] (open/close/move keys), so an empty `match = {}` rule is a global
# default and a specific rule tunes one app.
#
# Primitives:  opacity · scale · translate · wobble · wave · ripple · burn  (burn owns alpha)
#
# Presets:
#   none     instant — no animation
#   fade     opacity only
#   pop      opacity + scale-about-centre                (default `open`)
#   slide    opacity + translate in/out past a screen edge
#   drop     opacity + translate downward (close)
#   boing    spring-mesh "boing" spawn (open)
#   burn     noise dissolve + ember front (close)
#   wobble   spring-mesh jelly                           (default `move`)
#   stretch  a centre line grows to full WIDTH  (scale x; opaque, shows content)
#   unroll   a centre line grows to full HEIGHT (scale y; opaque, shows content)
#   minimize shrink to a point + slide off the bottom edge (simplified genie)
#   spin     rotate about the centre (full turn) + fade  (GPU)
#   wave     traveling sinusoidal crest (per-pixel refraction); rings down + settles flat
#   ripple   radial "drop in a lake" — per-pixel refraction from the centre out (GPU)
#   drain    whirlpool close — content spirals into a vanishing point + fades (GPU)
[anim]
open  = "pop"           # window mapped
close = "fade"          # window unmapped/destroyed
move  = "wobble"        # window moved/resized
focus = "none"          # in-place effect when a window gains focus: wave | ripple | wobble |
                        # spin | pop | stretch | unroll | slide | none. Per-window: [[rule]] focus = …
duration = 0.2          # default seconds for opacity / scale / translate
scale_from = 0.85       # default `scale` start factor (open) / end factor (close)
wobble_spring = 350.0   # default wobble spring stiffness k (higher = snappier)
wobble_friction = 14.0  # default wobble velocity damping (higher = less jiggle)
wave_amplitude = 0.04   # default `wave` amplitude (UV; fraction of the perpendicular side)
wave_wavelength = 0.5   # `wave` wavelength as a fraction of the axis (1.0 = one cycle across; 0.5 = two)
wave_speed = 1.5        # default `wave` crest travel speed (cycles/second)
wave_duration = 1.5     # default `wave` settle time (seconds; how long it lasts, <=0 loops)
ripple_amplitude = 0.08  # default `ripple` peak refraction (UV units; ~8% of the window)
ripple_wavelength = 0.18 # `ripple` ring spacing (fraction of the radius; smaller = more rings)
ripple_speed = 1.2       # default `ripple` ring expansion speed (cycles/second)
ripple_r0 = 0.12         # `ripple` spread — big rings at the centre, dying toward the rim
ripple_duration = 2.5    # default `ripple` settle time (seconds; how long it lasts, <=0 loops)
drain_turns = 1.5        # default `drain` swirl rotations at full progress (whirlpool close)
drain_duration = 0.6     # default `drain` close duration (seconds; content spirals to a point)

# Explicit block composition (overrides the preset for that category). Each block
# is a table tagged by `block`; a spec may set its own `duration`. `easing` is
# ease-out (default) | ease-in | linear. Example — Firefox drops in from above:
#
#   [[rule]]
#   match = { class = "firefox" }
#   [rule.open]
#   duration = 0.28
#   blocks = [
#     { block = "opacity", easing = "ease-out" },
#     { block = "translate", dy = -60.0, easing = "ease-in" },
#   ]
#
# Block params (all fields optional unless noted):
#   opacity   { from, easing }
#   scale     { from, axis = "both"|"x"|"y", easing }   # x/y = directional stretch
#   translate { dx, dy, edge = "left"|"right"|"top"|"bottom", easing }
#             #   edge = slide fully off that screen edge; else use dx/dy (px)
#   wobble    { spring, friction }
#   wave      { amplitude, wavelength, speed, axis = "x"|"y", duration } # sinusoidal (per-pixel)
#   ripple    { amplitude, wavelength, speed, r0, duration }           # radial refraction (GPU)
#   drain     { turns, duration }                                      # whirlpool close (GPU)
#   burn      # no params here — the dissolve look comes from [burn] below

[shadow]
enabled = true
radius = 12.0       # left/bottom falloff distance (px)
strength = 0.45     # peak shadow alpha (0.0-1.0)
min_size = 24       # skip shadows for windows smaller than this (px)

[blur]
enabled = false     # frost the backdrop behind translucent windows (extra GPU cost)
passes = 3          # dual-Kawase iterations (more = wider/softer)
radius = 4.0        # sample offset per pass (px)

[dim]
# Dim unfocused windows so the focused one stands out. Needs a focus signal (see
# `focus` below); with none it's inert. Exempt an app with a per-[[rule]] dim = false.
enabled = false     # opt in
strength = 0.3      # how much to dim an unfocused window: 0.0 = none, 1.0 = fully transparent
focus = "ewmh"      # focus source: "ewmh" = root _NET_ACTIVE_WINDOW (needs an EWMH WM);
                    # "x11" = X FocusChange events (works with a non-EWMH WM / focus-follows-
                    # mouse / XSetInputFocus — but still needs something to move X focus)

[osd]
# On-screen toast shown by `ricomctl notify "text" [secs]` — a top-center banner
# drawn by the SDF text engine. `open`/`close` pick how it appears/disappears.
enabled = true      # false = ignore notify requests
duration = 2.5      # default on-screen hold (seconds) when the command omits one
scale = 1.0         # size multiplier on top of automatic screen-height scaling
open  = "stretch"   # appear effect:  fade | slide | pop | unroll | stretch
close = "stretch"   # disappear effect (same set). stretch = grow/squeeze width;
                    # unroll = height; slide = drop from top; pop = zoom; fade = plain
in_dur  = 0.06      # appear-animation length (seconds); lower = snappier
out_dur = 0.08      # disappear-animation length (seconds)
ack = true          # toast a short confirmation for ping / reload / fps toggle
background = [0.05, 0.05, 0.07, 0.88]  # banner box colour (RGBA); set alpha = 0.0 for a
                    # text-only toast (no box). Keep `outline` on so it stays readable.
outline = true      # dark halo behind the glyphs — legible over any backdrop (bright windows,
                    # video) even with no box; harmless (hidden) behind an opaque box

[burn]
# The `burn` close effect's look. These knobs are live-tunable: edit and reload
# with  kill -HUP $(pidof ricom)  then close a `burn` window to see the change.
seg_scale = 36.0        # segment/hole granularity (higher = finer, smaller patches)
ember_width = 0.07      # ember hot-band half-width (smaller = thinner, tighter glow)
ember_cool = [0.28, 0.02, 0.0]  # cooler trailing ember colour (edge of the glow)
ember_hot  = [0.75, 0.22, 0.04] # hottest leading-edge colour; raise both for a brighter fire

[fps]
enabled = false          # start with the on-demand FPS HUD visible (also toggles live via the hotkey)
hotkey = "Super+Shift+F" # toggle the HUD (XGrabKey); the hotkey's modifiers + arrow keys move it
                         # between corners live (e.g. Super+Shift+Left)
corner = "bottom-left"   # initial corner: top-left | top-right | bottom-left | bottom-right
graph = true             # draw the rolling frame-time graph under the numbers
scale = 1.0              # size multiplier on top of automatic screen-height scaling (4K = 2x)
# The HUD also shows a 1m/5m/15m load block (fps + GPU render ms); the same
# figures are logged on demand via  kill -USR1 $(pidof ricom)

# Per-window rules. Each [[rule]] has a `match` (all listed conditions must hold —
# class/instance/window_type match exactly, title matches as a substring,
# fullscreen matches state) plus the settings it overrides: opacity / blur /
# shadow / corner_radius / unredir / above, and the per-category animations
# open / close / move (a preset name or an explicit [rule.<cat>] block spec).
# Rules apply in order, last match wins per field. A built-in rule already keeps
# fullscreen windows opaque + unblurred; add your own to override. Examples
# (uncomment to use):

# [[rule]]
# match = { class = "mpv" }         # video: never dim or blur, keep the burn on close
# opacity = 1.0
# blur = false
# shadow = false
# close = "burn"

# [[rule]]
# match = { instance = "xlogo" }   # a big wobbly toy: springs open (boing), fades on close.
# open = "boing"                   # `unredir = false` keeps it composited so the spring shows
# close = "fade"                   # even at fullscreen (otherwise it page-flips past the compositor).
# unredir = false

# [[rule]]
# match = {}                        # global default via a catch-all rule:
# close = "fade"                    # fade every window closed (same as [anim] close)

# [[rule]]
# match = { class = "com.mitchellh.ghostty" }  # frosted terminals (Ghostty's default
# opacity = 0.85                                # X11 class; confirm with `xprop WM_CLASS`,
# blur = true                                   # or set it via Ghostty's own `class` option)

# [[rule]]
# match = { window_type = "dock" }  # no shadow on panels/bars
# shadow = false

# [[rule]]
# match = { title = "Picture-in-Picture" }
# corner_radius = 12.0

# [[rule]]
# match = { title = "intel-gpu-top" }  # keep a monitor/HUD terminal always on top
# above = true                         # (composited topmost regardless of X stacking)
